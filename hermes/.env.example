# Railway service env vars (set in dashboard; never commit real values)

# Hermes reads config + secrets from the volume at this path (required on Railway)
HERMES_HOME=/opt/data

OPENCODE_GO_API_KEY=sk-your-opencode-go-key
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
API_SERVER_KEY=generate-a-long-random-string

API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_CORS_ORIGINS=*

# Required for public Railway URL — dashboard fails closed without auth on 0.0.0.0
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=choose-a-strong-password
HERMES_DASHBOARD_BASIC_AUTH_SECRET=generate-with-openssl-rand-base64-32

# Full autopilot — Hermes executes and notifies; Adam approves outreach only
OUTREACH_APPROVAL_REQUIRED=true
AUTO_MERGE_SEO_PRS=true

# Slack alternative to Telegram
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# Analytics
# GSC: base64-encode service account JSON → paste as one line (preferred on Railway)
# GSC_SERVICE_ACCOUNT_JSON_B64=
# Or mount file and set:
# GOOGLE_APPLICATION_CREDENTIALS=/opt/data/credentials/gsc-service-account.json
# GA4 property (must match site — see index.html)
GA4_PROPERTY_ID=G-CB5GL0P3EZ
# GA4_CREDENTIALS=/opt/data/credentials/ga4-service-account.json

# SEO intel
# SERPAPI_API_KEY=

# GitHub — auto PR, merge, publish blog/SEO changes
# GITHUB_TOKEN=
# GITHUB_REPO=your-org/saahomes

# Deploy after merge (Railway redeploy webhook or token)
# IMPORTANT: must be the saahomes.com WEBSITE service ID — NOT the Hermes service ID.
# If this points at Hermes, every blog deploy restarts the gateway ("Gateway shutting down").
# RAILWAY_TOKEN=
# RAILWAY_SERVICE_ID=

# Browserbase — optional; browse.sh market intel ONLY (not social posting)
# Dashboard: https://www.browserbase.com → Settings → API Key + Project ID
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Optional — keep sessions open longer during login/post (default 120)
# BROWSER_INACTIVITY_TIMEOUT=300

# Outreach send + social post packs — same Gmail app password
# OUTREACH_SMTP_HOST=smtp.gmail.com
# OUTREACH_SMTP_USER=adam@saahomes.com
# OUTREACH_SMTP_PASSWORD=app-specific-password
# SOCIAL_POST_EMAIL_TO=adam@saahomes.com
